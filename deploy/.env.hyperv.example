# Production environment template for deploy/docker-compose.hyperv.yml
# Copy to .env on the Ubuntu VM (cp .env.hyperv.example .env), fill in values, then:
#   docker compose -f docker-compose.hyperv.yml --env-file .env up -d --build

# ---- Postgres ------------------------------------------------------------
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=REPLACE_ME

# ---- JWT signing key (shared by auth / hub / files) ----------------------
# Generate with: openssl rand -base64 48
JWT_SIGNING_KEY=REPLACE_ME
JWT_ISSUER=aethernet-auth
JWT_AUDIENCE=aethernet-hub

# ---- Hub welcome banner --------------------------------------------------
MOTD=Welcome to Aethernet.

# ---- Cloudflare Tunnel ---------------------------------------------------
# Long opaque string from Cloudflare Zero Trust → Networks → Tunnels →
# (your tunnel) → Install connector → Docker. Starts with "eyJh..." — it's
# a JWT. The hostnames → service routing is configured in the Cloudflare UI,
# not here.
CLOUDFLARE_TUNNEL_TOKEN=REPLACE_ME

# ---- File storage --------------------------------------------------------
# Per-user quota in bytes. 5 GiB default; raise if your test crew sync heavy
# mods. Storage lives on the VM disk via a docker volume, so you're bounded
# by however big you made the VM's vhdx.
FILE_QUOTA_BYTES=5368709120

# ---- Discord OAuth (optional) -------------------------------------------
# Leave blank to disable.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
