# Copy to .env (next to docker-compose.cloud.yml) and fill in real values.
# Never commit the real .env — it's gitignored.

# ---- Postgres ----
# Strong random password. Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=REPLACE_ME

# ---- JWT ----
# Strong random key. Generate with: openssl rand -base64 48
JWT_SIGNING_KEY=REPLACE_ME
JWT_ISSUER=aethernet-auth
JWT_AUDIENCE=aethernet-hub

# ---- Discord OAuth (optional — leave blank to disable) ----
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ---- Cloudflare R2 ----
# Find your account ID in Cloudflare dashboard → R2 → Overview (right sidebar).
# Endpoint format: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=aethernet-blobs

# Generate via Cloudflare dashboard → R2 → Manage API Tokens.
# Permissions: "Object Read & Write" scoped to the aethernet-blobs bucket only.
R2_ACCESS_KEY=REPLACE_ME
R2_SECRET_KEY=REPLACE_ME

# ---- Quotas ----
# Per-user blob quota in bytes. 20 GiB default.
FILE_QUOTA_BYTES=21474836480

# ---- Server greeting (optional) ----
MOTD=Welcome to Aethernet.

# ---- Domains served by Caddy (TLS via Let's Encrypt) ----
DOMAIN_AUTH=auth-aethernet.heimiyano.com
DOMAIN_HUB=hub-aethernet.heimiyano.com
DOMAIN_FILES=files-aethernet.heimiyano.com
ACME_EMAIL=your-email@example.com
