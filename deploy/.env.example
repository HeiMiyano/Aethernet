# Production environment template for deploy/docker-compose.prod.yml
# Copy to .env on the EC2 host (cp .env.example .env), fill in real values, then:
#   docker compose -f docker-compose.prod.yml --env-file .env up -d --build
#
# Never commit the populated .env. The .gitignore at repo root excludes it.

# ---- Postgres ------------------------------------------------------------
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=REPLACE_ME

# ---- JWT signing key (shared by auth / hub / files) ----------------------
# All three services must agree on this. Auth issues; hub + files verify.
# Generate with: openssl rand -base64 48
JWT_SIGNING_KEY=REPLACE_ME
JWT_ISSUER=aethernet-auth
JWT_AUDIENCE=aethernet-hub

# ---- Hub welcome banner --------------------------------------------------
MOTD=Welcome to Aethernet.

# ---- Subdomains (must match DNS A records pointing at this host) ---------
DOMAIN_AUTH=auth.aethernet.heimiyano.com
DOMAIN_HUB=hub.aethernet.heimiyano.com
DOMAIN_FILES=files.aethernet.heimiyano.com

# ---- Let's Encrypt notifications ----------------------------------------
# Used for cert expiry warnings. Real email; LE will not validate it but it's
# how you find out if a renewal fails silently.
ACME_EMAIL=miyanohei@gmail.com

# ---- AWS S3 (for mod blobs) ---------------------------------------------
# If the EC2 has an IAM instance role with S3 access, leave the key fields blank
# and the AWS SDK picks the role up automatically. RECOMMENDED — no static
# credentials stored on disk. The runbook covers attaching the role.
AWS_REGION=us-east-1
S3_BUCKET=aethernet-blobs-heimiyano   # globally-unique; pick whatever's free
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Per-user file quota (bytes). 5 GiB default — bump up if your friends sync
# heavy mods. Storage on S3 is ~$0.023 per GB-month at this scale.
FILE_QUOTA_BYTES=5368709120

# ---- Discord OAuth (optional) -------------------------------------------
# Leave blank to disable Discord-based registration. If you set these,
# register an application at https://discord.com/developers and put the
# callback URL https://${DOMAIN_AUTH}/auth/oauth/discord/cb in its OAuth2 settings.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
